# Local SQLite databases produced by the scraper
*.db
*.sqlite
*.sqlite3

# Downloaded page cache
html_cache/

# Manually saved compendium pages (fed to `wheeldb ingest --from-dir`).
# Root-anchored so they never shadow tracked fixtures under tests/fixtures/.
/pages/
/compendium*.htm
/compendium*.html
/compendium*_files/

# Generated game files (wheeldb game -> games/wof[N].pptm)
/games/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.coverage
*.egg-info/
